#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
secret_file="$repo_root/clusters/lab/apps/baby-monitor/ghcr-pull.sops.yaml"
sops_bin="${SOPS_BIN:-$repo_root/.tools/bin/sops}"
age_key_file="${SOPS_AGE_KEY_FILE:-$repo_root/.secrets/age.key}"

if [[ ! -x "$sops_bin" ]]; then
  echo "sops not found at $sops_bin" >&2
  exit 1
fi

if [[ ! -f "$age_key_file" ]]; then
  echo "age key not found at $age_key_file" >&2
  exit 1
fi

if [[ -e "$secret_file" ]]; then
  echo "Refusing to overwrite existing $secret_file" >&2
  exit 1
fi

read -r -p "GHCR username [kadencartwright]: " username
username="${username:-kadencartwright}"
read -r -s -p "GHCR token with read:packages: " token
printf '\n'

if [[ -z "$token" ]]; then
  echo "token is required" >&2
  exit 1
fi

auth="$(printf '%s:%s' "$username" "$token" | base64 -w0)"
dockerconfig="$(printf '{"auths":{"ghcr.io":{"username":"%s","password":"%s","auth":"%s"}}}' "$username" "$token" "$auth" | base64 -w0)"
tmp="$(mktemp "$repo_root/clusters/lab/apps/baby-monitor/.ghcr-pull.XXXXXX.sops.yaml")"
cleanup() {
  rm -f "$tmp"
}
trap cleanup EXIT

cat > "$tmp" <<EOF
---
apiVersion: v1
kind: Secret
metadata:
  name: ghcr-pull
  namespace: baby-monitor
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: "$dockerconfig"
EOF

SOPS_AGE_KEY_FILE="$age_key_file" "$sops_bin" --encrypt "$tmp" > "$secret_file"
chmod 600 "$secret_file"

echo "Created encrypted pull secret: $secret_file"
