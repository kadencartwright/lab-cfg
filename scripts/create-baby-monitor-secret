#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
secret_file="$repo_root/clusters/lab/apps/baby-monitor/config.sops.yaml"
sops_bin="${SOPS_BIN:-$repo_root/.tools/bin/sops}"
age_key_file="${SOPS_AGE_KEY_FILE:-$repo_root/.secrets/age.key}"
default_source="$repo_root/../baby-monitor/deploy/kubernetes/secret.local.yaml"
source_secret="${BABY_MONITOR_SECRET_SOURCE:-$default_source}"

if [[ ! -x "$sops_bin" ]]; then
  echo "sops not found at $sops_bin" >&2
  exit 1
fi

if [[ ! -f "$age_key_file" ]]; then
  echo "age key not found at $age_key_file" >&2
  exit 1
fi

if [[ -e "$secret_file" && "${OVERWRITE:-}" != "1" ]]; then
  echo "Refusing to overwrite existing $secret_file" >&2
  echo "Set OVERWRITE=1 to intentionally replace it." >&2
  exit 1
fi

encrypt_secret_file() {
  local source_file="$1"
  local tmp

  if ! grep -Eq '^kind:[[:space:]]*Secret[[:space:]]*$' "$source_file"; then
    echo "$source_file is not a Kubernetes Secret manifest" >&2
    exit 1
  fi

  if ! grep -Eq '^[[:space:]]+name:[[:space:]]*baby-monitor-config[[:space:]]*$' "$source_file"; then
    echo "$source_file must use metadata.name: baby-monitor-config" >&2
    exit 1
  fi

  if ! grep -Eq '^[[:space:]]+namespace:[[:space:]]*baby-monitor[[:space:]]*$' "$source_file"; then
    echo "$source_file must use metadata.namespace: baby-monitor" >&2
    exit 1
  fi

  if ! grep -Eq '^[[:space:]]+BABY_MONITOR_ACCESS_TOKEN:' "$source_file"; then
    echo "$source_file must define BABY_MONITOR_ACCESS_TOKEN" >&2
    exit 1
  fi

  if ! grep -Eq '^[[:space:]]+BABY_MONITOR_CAMERAS_JSON:' "$source_file"; then
    echo "$source_file must define BABY_MONITOR_CAMERAS_JSON" >&2
    exit 1
  fi

  tmp="$(mktemp "$repo_root/clusters/lab/apps/baby-monitor/.config.XXXXXX.sops.yaml")"
  SOPS_AGE_KEY_FILE="$age_key_file" "$sops_bin" \
    --filename-override "$secret_file" \
    --encrypt "$source_file" > "$tmp"
  chmod 600 "$tmp"
  mv "$tmp" "$secret_file"
}

if [[ -n "$source_secret" && -f "$source_secret" ]]; then
  encrypt_secret_file "$source_secret"
  echo "Created encrypted config secret from existing Kubernetes Secret: $secret_file"
  exit 0
fi

if [[ "${BABY_MONITOR_SECRET_SOURCE:-}" != "" ]]; then
  echo "BABY_MONITOR_SECRET_SOURCE does not exist: $BABY_MONITOR_SECRET_SOURCE" >&2
  exit 1
fi

default_token="$(openssl rand -base64 32 | tr -d '\n')"
read -r -p "Baby monitor access token [generate random]: " access_token
access_token="${access_token:-$default_token}"
read -r -p "Camera JSON file path [empty camera list]: " camera_json_path

if [[ -n "$camera_json_path" ]]; then
  cameras_json="$(cat "$camera_json_path")"
else
  cameras_json="[]"
fi

tmp="$(mktemp "$repo_root/clusters/lab/apps/baby-monitor/.config.XXXXXX.sops.yaml")"
cleanup() {
  rm -f "$tmp"
}
trap cleanup EXIT

cat > "$tmp" <<EOF
---
apiVersion: v1
kind: Secret
metadata:
  name: baby-monitor-config
  namespace: baby-monitor
type: Opaque
stringData:
  BABY_MONITOR_ACCESS_TOKEN: "$access_token"
  BABY_MONITOR_CAMERAS_JSON: |
$(printf '%s\n' "$cameras_json" | sed 's/^/    /')
EOF

SOPS_AGE_KEY_FILE="$age_key_file" "$sops_bin" --encrypt "$tmp" > "$secret_file"
chmod 600 "$secret_file"

mkdir -p "$repo_root/.secrets"
chmod 700 "$repo_root/.secrets"
printf '%s\n' "$access_token" > "$repo_root/.secrets/baby-monitor-access-token"
chmod 600 "$repo_root/.secrets/baby-monitor-access-token"

echo "Created encrypted config secret: $secret_file"
echo "Stored local access token backup: .secrets/baby-monitor-access-token"
