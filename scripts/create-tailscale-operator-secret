#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
secret_file="$repo_root/clusters/lab/infrastructure/tailscale-operator/operator-oauth.sops.yaml"
sops_bin="${SOPS_BIN:-$repo_root/.tools/bin/sops}"
age_key_file="${SOPS_AGE_KEY_FILE:-$repo_root/.secrets/age.key}"

if [[ ! -x "$sops_bin" ]]; then
  echo "sops not found at $sops_bin" >&2
  exit 1
fi

if [[ ! -f "$age_key_file" ]]; then
  echo "age key not found at $age_key_file" >&2
  exit 1
fi

if [[ -e "$secret_file" ]]; then
  echo "Refusing to overwrite existing $secret_file" >&2
  exit 1
fi

read -r -p "Tailscale OAuth client ID: " client_id
read -r -s -p "Tailscale OAuth client secret: " client_secret
printf '\n'

if [[ -z "$client_id" || -z "$client_secret" ]]; then
  echo "client ID and secret are required" >&2
  exit 1
fi

tmp="$(mktemp "$repo_root/clusters/lab/infrastructure/tailscale-operator/.operator-oauth.XXXXXX.sops.yaml")"
cleanup() {
  rm -f "$tmp"
}
trap cleanup EXIT

cat > "$tmp" <<EOF
---
apiVersion: v1
kind: Secret
metadata:
  name: operator-oauth
  namespace: tailscale
stringData:
  client_id: "$client_id"
  client_secret: "$client_secret"
EOF

SOPS_AGE_KEY_FILE="$age_key_file" "$sops_bin" --encrypt "$tmp" > "$secret_file"
chmod 600 "$secret_file"

echo "Created encrypted secret: $secret_file"
echo "Review with: SOPS_AGE_KEY_FILE=$age_key_file $sops_bin --decrypt $secret_file"
